# Copy this file to `.env.local` and fill in real values from your Supabase
# project dashboard at: https://supabase.com/dashboard/project/<id>/settings/api

# Project URL  e.g.  https://xxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Publishable / anon key  (NEVER use the service_role key in the frontend)
VITE_SUPABASE_PUBLISHABLE_KEY=
